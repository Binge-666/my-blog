---
// src/pages/about.astro
// 关于页面
import Layout from '../layouts/Layout.astro';
---

<Layout title="关于 | 我的博客">
  <div class="max-w-4xl mx-auto">
    <!-- 页面标题 -->
    <h1 class="text-4xl font-bold text-primary-700 mb-8">关于</h1>
    
    <!-- 主要内容区域 -->
    <div class="prose prose-lg max-w-none">
      <!-- 个人介绍 -->
      <section class="mb-12">
        <h2 class="text-3xl font-semibold text-primary-700 mb-6">关于我</h2>
        <div class="bg-white rounded-2xl shadow-sm p-8">
          <p class="text-primary-500 mb-4">
            欢迎来到我的技术博客！我是<span class="font-medium text-primary-600">AI开发者和技术布道者</span>，专注于人工智能技术的实际应用与开发实践。
          </p>
          <p class="text-primary-500 mb-4">
            拥有多年软件开发经验，目前主要研究方向包括大语言模型应用、Agent开发、全栈工程架构等前沿技术领域。
          </p>
          <p class="text-primary-500">
            我相信技术应该服务于人，通过博客分享我的学习和实践经验，希望能帮助更多开发者成长。
          </p>
        </div>
      </section>

      <!-- 技术专长 -->
      <section class="mb-12">
        <h2 class="text-3xl font-semibold text-primary-700 mb-6">技术专长</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-white rounded-2xl shadow-sm p-6">
            <h3 class="text-xl font-semibold text-primary-700 mb-4">人工智能与机器学习</h3>
            <ul class="space-y-2 text-primary-500">
              <li class="flex items-center">
                <svg class="w-5 h-5 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                大语言模型应用开发
              </li>
              <li class="flex items-center">
                <svg class="w-5 h-5 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                智能Agent开发
              </li>
              <li class="flex items-center">
                <svg class="w-5 h-5 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                自动化工作流
              </li>
            </ul>
          </div>
          
          <div class="bg-white rounded-2xl shadow-sm p-6">
            <h3 class="text-xl font-semibold text-primary-700 mb-4">全栈开发</h3>
            <ul class="space-y-2 text-primary-500">
              <li class="flex items-center">
                <svg class="w-5 h-5 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                前端框架 (React/Vue)
              </li>
              <li class="flex items-center">
                <svg class="w-5 h-5 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                后端开发 (Node.js/Python)
              </li>
              <li class="flex items-center">
                <svg class="w-5 h-5 text-green-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                数据库与系统设计
              </li>
            </ul>
          </div>
        </div>
      </section>

      <!-- 博客项目信息 -->
      <section class="mb-12">
        <h2 class="text-3xl font-semibold text-primary-700 mb-6">关于这个博客</h2>
        <div class="bg-white rounded-2xl shadow-sm p-8">
          <div class="mb-6">
            <h3 class="text-xl font-semibold text-primary-700 mb-3">技术栈</h3>
            <p class="text-primary-500 mb-4">
              本博客基于 <span class="font-medium text-primary-600">Astro 6.1.9</span> 构建，这是一个现代化的静态站点生成器，提供极致的性能和开发体验。
            </p>
            <div class="flex flex-wrap gap-3 mt-4">
              <span class="px-4 py-2 bg-primary-50 text-primary-700 rounded-full text-sm font-medium">Astro 6.1.9</span>
              <span class="px-4 py-2 bg-green-50 text-green-700 rounded-full text-sm font-medium">TailwindCSS 4.2.4</span>
              <span class="px-4 py-2 bg-purple-50 text-purple-700 rounded-full text-sm font-medium">TypeScript</span>
              <span class="px-4 py-2 bg-yellow-50 text-yellow-700 rounded-full text-sm font-medium">响应式设计</span>
            </div>
          </div>
          
          <div>
            <h3 class="text-xl font-semibold text-primary-700 mb-3">博客目标</h3>
            <ul class="space-y-3 text-primary-500">
              <li class="flex items-start">
                <svg class="w-5 h-5 text-primary-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                分享技术洞见和开发经验
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-primary-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                记录AI技术的学习和应用过程
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-primary-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                构建开发者社区，促进技术交流
              </li>
            </ul>
          </div>
        </div>
      </section>

      <!-- 联系信息 -->
      <section>
        <h2 class="text-3xl font-semibold text-primary-700 mb-6">联系我</h2>
        <div class="bg-white rounded-2xl shadow-sm p-8">
          <p class="text-primary-500 mb-6">
            如果您对博客内容有任何疑问、建议，或者希望探讨技术合作，欢迎通过以下方式联系我：
          </p>
          
          <div class="space-y-4">
            <div class="flex items-center">
              <svg class="w-6 h-6 text-primary-500 mr-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <span class="text-primary-500">邮箱: contact@myblog.dev</span>
            </div>
            
            <div class="flex items-center">
              <svg class="w-6 h-6 text-primary-500 mr-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z" />
              </svg>
              <span class="text-primary-500">技术交流: 欢迎在文章下方留言讨论</span>
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>
</Layout>

<style>
  /* 自定义样式 */
  .prose a {
    color: #2563eb;
    text-decoration: none;
  }
  .prose a:hover {
    text-decoration: underline;
  }
</style>