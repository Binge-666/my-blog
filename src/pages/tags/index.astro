---
// src/pages/tags/index.astro
// 标签聚合页 - 按标签分类展示所有文章

import Layout from '../../layouts/Layout.astro';

// 获取所有文章
const postModules = import.meta.glob('../../content/posts/*.md', { eager: true });

// 提取所有标签和文章
const allPosts = Object.entries(postModules)
  .map(([filePath, module]) => {
    const slug = filePath.split('/').pop()?.replace('.md', '') || '';
    return {
      slug,
      ...module.frontmatter,
    };
  })
  .filter(post => post.title && post.pubDate && !post.draft)
  .sort((a, b) => new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime());

// 按标签分组
const tagGroups: Record<string, typeof allPosts> = {};
allPosts.forEach(post => {
  if (post.tags && Array.isArray(post.tags)) {
    post.tags.forEach(tag => {
      if (!tagGroups[tag]) {
        tagGroups[tag] = [];
      }
      tagGroups[tag].push(post);
    });
  }
});

// 获取所有唯一标签
const allTags = Object.keys(tagGroups).sort();
---

<Layout title="标签 | Binge博客">
  <div class="max-w-6xl mx-auto">
    <!-- 页面标题 -->
    <header class="mb-12 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-primary-700 mb-4">标签</h1>
      <p class="text-lg text-primary-500">共 {allTags.length} 个标签，{allPosts.length} 篇文章</p>
    </header>

    <!-- 标签云 -->
    <div class="mb-12 flex flex-wrap justify-center gap-3">
      {allTags.map(tag => (
        <a 
          href={`#${tag}`}
          class="px-4 py-2 bg-primary-100 text-primary-700 rounded-full hover:bg-primary-200 transition-colors font-medium"
        >
          #{tag}
          <span class="ml-1 text-sm text-primary-400">({tagGroups[tag].length})</span>
        </a>
      ))}
    </div>

    <!-- 按标签分组的文章列表 -->
    <div class="space-y-12">
      {allTags.map(tag => (
        <section id={tag} class="scroll-mt-20">
          <div class="flex items-center mb-6">
            <span class="text-2xl font-bold text-primary-700 mr-3">#{tag}</span>
            <span class="text-sm text-primary-400">{tagGroups[tag].length} 篇文章</span>
          </div>
          
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {tagGroups[tag].map(post => (
              <a 
                href={`/posts/${post.slug}`}
                class="block p-6 bg-white rounded-xl border border-primary-100 hover:border-primary-300 hover:shadow-lg transition-all"
              >
                <h3 class="text-lg font-semibold text-primary-700 mb-2 line-clamp-2">{post.title}</h3>
                <p class="text-sm text-primary-400 mb-3 line-clamp-2">{post.description}</p>
                <div class="flex items-center text-xs text-primary-300">
                  <time datetime={new Date(post.pubDate).toISOString()}>
                    {new Date(post.pubDate).toLocaleDateString('zh-CN', {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric'
                    })}
                  </time>
                  <span class="mx-2">•</span>
                  <span>{post.author || '博主'}</span>
                </div>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>
</Layout>
