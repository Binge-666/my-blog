---
// src/pages/admin.astro
// 博客后台管理界面
import Layout from '../layouts/Layout.astro';

// 获取当前所有文章
const postModules = import.meta.glob('../content/posts/*.md', { eager: true });

// 处理文章数据
const posts = Object.entries(postModules).map(([filePath, module]) => {
  const slug = filePath
    .split('/')
    .pop()
    ?.replace('.md', '') || '';
    
  return {
    slug,
    frontmatter: module.frontmatter,
    body: module.body,
    filename: filePath.split('/').pop()
  };
}).sort((a, b) => {
  const dateA = a.frontmatter.pubDate ? new Date(a.frontmatter.pubDate) : new Date(0);
  const dateB = b.frontmatter.pubDate ? new Date(b.frontmatter.pubDate) : new Date(0);
  return dateB.getTime() - dateA.getTime();
});

// 获取当前日期
const currentDate = new Date().toISOString().split('T')[0];
---

<Layout title="后台管理 | 我的博客">
  <div class="max-w-6xl mx-auto">
    <!-- 页面标题 -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-primary-700 mb-4 flex items-center">
        <i class="ri-settings-3-line text-primary-600 mr-3"></i>博客后台管理
      </h1>
      <p class="text-primary-400">管理博客内容、发布新文章、查看统计数据</p>
    </div>

    <!-- 操作卡片区域 -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <!-- 创建新文章 -->
      <div class="bg-white rounded-2xl shadow-sm border border-primary-200 p-6">
        <div class="flex items-center mb-4">
          <div class="w-12 h-12 bg-primary-100 rounded-xl flex items-center justify-center mr-4">
            <i class="ri-add-line text-primary-600 text-2xl"></i>
          </div>
          <h3 class="text-xl font-semibold text-primary-700">创建新文章</h3>
        </div>
        <p class="text-primary-400 mb-6">通过以下方式创建新文章：</p>
        
        <div class="space-y-4">
          <!-- 方法1: 手动创建Markdown文件 -->
          <div class="border border-primary-200 rounded-xl p-4">
            <h4 class="font-semibold text-primary-700 mb-2 flex items-center">
              <i class="ri-file-mark-line text-primary-500 mr-2"></i>方法1: 手动创建文件
            </h4>
            <p class="text-sm text-primary-400 mb-3">在 <code class="bg-primary-100 px-2 py-1 rounded">src/content/posts/</code> 目录下创建新的 .md 文件</p>
            <div class="text-sm text-primary-500 space-y-2">
              <div class="flex items-center">
                <i class="ri-checkbox-circle-line text-green-500 mr-2"></i>
                <span>文件命名: 英文短横线分隔，如: my-new-post.md</span>
              </div>
              <div class="flex items-center">
                <i class="ri-checkbox-circle-line text-green-500 mr-2"></i>
                <span>包含frontmatter元数据和Markdown内容</span>
              </div>
            </div>
          </div>
          
          <!-- 方法2: 使用模板 -->
          <div class="border border-primary-200 rounded-xl p-4">
            <h4 class="font-semibold text-primary-700 mb-2 flex items-center">
              <i class="ri-code-s-slash-line text-purple-500 mr-2"></i>方法2: 使用模板
            </h4>
            <p class="text-sm text-primary-400 mb-3">复制以下模板创建新文章：</p>
            <div class="bg-primary-700 text-gray-100 p-4 rounded-lg text-sm overflow-x-auto">
<pre><code>---
title: "文章标题"
pubDate: {currentDate}
description: "文章描述"
author: "您的名字"
tags: ["标签1", "标签2"]
---

# 文章标题

这里是文章正文内容...

## 二级标题

正文段落...

### 三级标题

更多内容...</code></pre>
            </div>
          </div>
          
          <!-- 方法3: 通过编辑器 -->
          <div class="border border-primary-200 rounded-xl p-4">
            <h4 class="font-semibold text-primary-700 mb-2 flex items-center">
              <i class="ri-edit-line text-green-500 mr-2"></i>方法3: 在线编辑器
            </h4>
            <p class="text-sm text-primary-400 mb-3">使用Markdown编辑器创建内容：</p>
            <div class="flex space-x-3">
              <a href="https://stackedit.io/" target="_blank" class="inline-flex items-center text-primary-600 hover:text-primary-700 text-sm">
                <i class="ri-external-link-line mr-1"></i>StackEdit
              </a>
              <a href="https://dillinger.io/" target="_blank" class="inline-flex items-center text-primary-600 hover:text-primary-700 text-sm">
                <i class="ri-external-link-line mr-1"></i>Dillinger
              </a>
            </div>
          </div>
        </div>
      </div>
      
      <!-- 文章管理 -->
      <div class="bg-white rounded-2xl shadow-sm border border-primary-200 p-6">
        <div class="flex items-center mb-4">
          <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center mr-4">
            <i class="ri-article-line text-green-600 text-2xl"></i>
          </div>
          <h3 class="text-xl font-semibold text-primary-700">文章管理</h3>
        </div>
        
        <div class="mb-6">
          <div class="flex items-center justify-between mb-4">
            <h4 class="font-semibold text-primary-700">当前文章 ({posts.length})</h4>
            <div class="text-sm text-primary-400 flex items-center">
              <i class="ri-refresh-line mr-2"></i>实时更新
            </div>
          </div>
          
          {posts.length > 0 ? (
            <div class="space-y-3 max-h-96 overflow-y-auto pr-2">
              {posts.map((post) => (
                <div 
                  key={post.slug}
                  class="border border-primary-200 rounded-xl p-4 hover:bg-primary-50 transition-colors"
                >
                  <div class="flex justify-between items-start mb-2">
                    <h5 class="font-medium text-primary-700 truncate">{post.frontmatter.title}</h5>
                    <div class="flex items-center text-xs text-primary-400">
                      <i class="ri-calendar-line mr-1"></i>
                      {post.frontmatter.pubDate ? new Date(post.frontmatter.pubDate).toLocaleDateString('zh-CN') : '无日期'}
                    </div>
                  </div>
                  
                  <p class="text-sm text-primary-400 mb-3 truncate">{post.frontmatter.description}</p>
                  
                  <div class="flex justify-between items-center">
                    <div class="flex items-center">
                      <a 
                        href={`/posts/${post.slug}`} 
                        target="_blank"
                        class="inline-flex items-center text-primary-600 hover:text-primary-700 text-sm mr-4"
                      >
                        <i class="ri-eye-line mr-1"></i>查看
                      </a>
                      <span class="text-xs text-primary-400">
                        文件: {post.filename}
                      </span>
                    </div>
                    
                    {post.frontmatter.tags && post.frontmatter.tags.length > 0 && (
                      <div class="flex gap-1">
                        {post.frontmatter.tags.slice(0, 2).map((tag) => (
                          <span 
                            class="px-2 py-1 bg-primary-100 text-primary-400 text-xs rounded-full"
                            key={tag}
                          >
                            #{tag}
                          </span>
                        ))}
                        {post.frontmatter.tags.length > 2 && (
                          <span class="text-xs text-primary-300">+{post.frontmatter.tags.length - 2}</span>
                        )}
                      </div>
                    )}
                  </div>
                </div>
              ))}
            </div>
          ) : (
            <div class="text-center py-8 text-primary-400">
              <i class="ri-inbox-line text-4xl mb-3"></i>
              <p>暂无文章，请先创建您的第一篇文章</p>
            </div>
          )}
        </div>
      </div>
    </div>

    <!-- 快捷操作指南 -->
    <div class="bg-white rounded-2xl shadow-sm border border-primary-200 p-6 mb-8">
      <h3 class="text-xl font-semibold text-primary-700 mb-6 flex items-center">
        <i class="ri-guide-line text-orange-500 mr-3"></i>快速操作指南
      </h3>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="border border-primary-200 rounded-xl p-5">
          <div class="flex items-center mb-3">
            <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center mr-3">
              <i class="ri-terminal-line text-primary-600"></i>
            </div>
            <h4 class="font-semibold text-primary-700">通过终端创建</h4>
          </div>
          <div class="bg-primary-700 text-gray-100 p-3 rounded-lg text-sm overflow-x-auto">
<pre><code># 进入项目目录
cd my-blog

# 创建新文章
echo '---
title: "新文章标题"
pubDate: {currentDate}
description: "文章描述"
author: "您的名字"
tags: ["标签"]
---

# 正文内容

开始写作...' > src/content/posts/new-article.md</code></pre>
          </div>
        </div>
        
        <div class="border border-primary-200 rounded-xl p-5">
          <div class="flex items-center mb-3">
            <div class="w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center mr-3">
              <i class="ri-refresh-line text-purple-600"></i>
            </div>
            <h4 class="font-semibold text-primary-700">开发服务器</h4>
          </div>
          <p class="text-primary-400 mb-4">保存文件后，开发服务器会自动检测变化并重新构建页面。</p>
          <div class="space-y-2">
            <div class="flex items-center text-sm text-primary-500">
              <i class="ri-checkbox-circle-line text-green-500 mr-2"></i>
              <span>实时预览: http://localhost:4321</span>
            </div>
            <div class="flex items-center text-sm text-primary-500">
              <i class="ri-checkbox-circle-line text-green-500 mr-2"></i>
              <span>热重载: 修改文件后自动刷新</span>
            </div>
          </div>
        </div>
        
        <div class="border border-primary-200 rounded-xl p-5">
          <div class="flex items-center mb-3">
            <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center mr-3">
              <i class="ri-cloud-line text-green-600"></i>
            </div>
            <h4 class="font-semibold text-primary-700">部署发布</h4>
          </div>
          <p class="text-primary-400 mb-4">构建静态站点并部署到云平台：</p>
          <div class="space-y-3">
            <div class="text-sm">
              <div class="font-medium text-primary-700 mb-1">构建命令：</div>
              <div class="bg-primary-700 text-gray-100 p-2 rounded-lg font-mono text-xs">
                npm run build
              </div>
            </div>
            <div class="flex items-center justify-between text-sm">
              <span class="text-primary-400">推荐平台：</span>
              <div class="flex space-x-2">
                <a href="https://vercel.com" target="_blank" class="text-primary-600 hover:underline">Vercel</a>
                <span class="text-primary-200">|</span>
                <a href="https://netlify.com" target="_blank" class="text-primary-600 hover:underline">Netlify</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 状态统计 -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-primary-50 border border-primary-200 rounded-xl p-5">
        <div class="flex items-center">
          <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center mr-4">
            <i class="ri-article-line text-primary-600"></i>
          </div>
          <div>
            <div class="text-2xl font-bold text-primary-700">{posts.length}</div>
            <div class="text-sm text-primary-400">文章总数</div>
          </div>
        </div>
      </div>
      
      <div class="bg-green-50 border border-green-200 rounded-xl p-5">
        <div class="flex items-center">
          <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center mr-4">
            <i class="ri-calendar-line text-green-600"></i>
          </div>
          <div>
            <div class="text-2xl font-bold text-primary-700">
              {posts.length > 0 ? new Date(posts[0].frontmatter.pubDate).toLocaleDateString('zh-CN') : '无'}
            </div>
            <div class="text-sm text-primary-400">最新文章</div>
          </div>
        </div>
      </div>
      
      <div class="bg-purple-50 border border-purple-200 rounded-xl p-5">
        <div class="flex items-center">
          <div class="w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center mr-4">
            <i class="ri-hashtag text-purple-600"></i>
          </div>
          <div>
            <div class="text-2xl font-bold text-primary-700">
              {[...new Set(posts.flatMap(p => p.frontmatter.tags || []))].length}
            </div>
            <div class="text-sm text-primary-400">标签数量</div>
          </div>
        </div>
      </div>
      
      <div class="bg-orange-50 border border-orange-200 rounded-xl p-5">
        <div class="flex items-center">
          <div class="w-10 h-10 bg-orange-100 rounded-lg flex items-center justify-center mr-4">
            <i class="ri-terminal-line text-orange-600"></i>
          </div>
          <div>
            <div class="text-2xl font-bold text-primary-700">Astro</div>
            <div class="text-sm text-primary-400">技术栈</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  /* 自定义滚动条样式 */
  .overflow-y-auto::-webkit-scrollbar {
    width: 6px;
  }
  
  .overflow-y-auto::-webkit-scrollbar-track {
    background: #f1f1f1;
    border-radius: 3px;
  }
  
  .overflow-y-auto::-webkit-scrollbar-thumb {
    background: #c1c1c1;
    border-radius: 3px;
  }
  
  .overflow-y-auto::-webkit-scrollbar-thumb:hover {
    background: #a1a1a1;
  }
</style>
