---
// src/pages/search.astro
// 搜索页面 - 支持标题、内容、标签搜索

import Layout from '../layouts/Layout.astro';

// 获取所有文章
const postModules = import.meta.glob('../content/posts/*.md', { eager: true });

// 提取文章数据（只搜索标题、描述和标签，不搜索内容以避免构建问题）
const posts = Object.entries(postModules)
  .map(([filePath, module]) => {
    const slug = filePath.split('/').pop()?.replace('.md', '') || '';
    return {
      slug,
      ...module.frontmatter,
    };
  })
  .filter(post => post.title && post.pubDate && !post.draft)
  .sort((a, b) => new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime());
---

<Layout title="搜索 | Binge博客">
  <div class="max-w-4xl mx-auto">
    <!-- 页面标题 -->
    <header class="mb-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-primary-700 mb-4">搜索</h1>
      <p class="text-lg text-primary-500">搜索文章标题、内容和标签</p>
    </header>

    <!-- 搜索框 -->
    <div class="mb-8">
      <div class="relative">
        <input 
          type="text" 
          id="search-input"
          placeholder="输入关键词搜索..."
          class="w-full px-6 py-4 text-lg border-2 border-primary-200 rounded-xl focus:outline-none focus:border-primary-400 transition-colors bg-white"
          autocomplete="off"
        >
        <svg class="absolute right-4 top-1/2 transform -translate-y-1/2 w-6 h-6 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>
      <div id="search-stats" class="mt-4 text-sm text-primary-400 text-center"></div>
    </div>

    <!-- 搜索结果 -->
    <div id="search-results" class="space-y-6">
      <!-- 默认显示所有文章 -->
      <div id="default-results">
        <h2 class="text-xl font-semibold text-primary-700 mb-4">所有文章</h2>
        <div class="space-y-4">
          {posts.map(post => (
            <a 
              href={`/posts/${post.slug}`}
              class="block p-6 bg-white rounded-xl border border-primary-100 hover:border-primary-300 hover:shadow-lg transition-all"
              data-title={post.title}
              data-description={post.description || ''}
              data-tags={post.tags?.join(' ') || ''}
            >
              <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
                <div class="flex-1">
                  <h3 class="text-lg font-semibold text-primary-700 mb-2">{post.title}</h3>
                  <p class="text-sm text-primary-400 mb-3 line-clamp-2">{post.description}</p>
                  <div class="flex flex-wrap gap-2">
                    {post.tags?.slice(0, 3).map(tag => (
                      <span class="px-2 py-1 bg-primary-50 text-primary-600 text-xs rounded-full">
                        #{tag}
                      </span>
                    ))}
                  </div>
                </div>
                <div class="text-sm text-primary-300 md:text-right">
                  <time datetime={new Date(post.pubDate).toISOString()}>
                    {new Date(post.pubDate).toLocaleDateString('zh-CN', {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric'
                    })}
                  </time>
                  <div>{post.author || '博主'}</div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- 搜索结果（默认隐藏） -->
      <div id="filtered-results" class="hidden">
        <h2 class="text-xl font-semibold text-primary-700 mb-4">搜索结果</h2>
        <div id="filtered-list" class="space-y-4"></div>
      </div>
    </div>
  </div>
</Layout>

<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
  const searchInput = document.getElementById('search-input');
  const defaultResults = document.getElementById('default-results');
  const filteredResults = document.getElementById('filtered-results');
  const filteredList = document.getElementById('filtered-list');
  const searchStats = document.getElementById('search-stats');
  
  const articles = document.querySelectorAll('[data-title]');
  
  function performSearch(query) {
    if (!query.trim()) {
      defaultResults.classList.remove('hidden');
      filteredResults.classList.add('hidden');
      searchStats.textContent = '';
      return;
    }
    
    const lowerQuery = query.toLowerCase();
    const results = [];
    
    articles.forEach(article => {
      const title = article.dataset.title?.toLowerCase() || '';
      const description = article.dataset.description?.toLowerCase() || '';
      const tags = article.dataset.tags?.toLowerCase() || '';
      
      if (title.includes(lowerQuery) || 
          description.includes(lowerQuery) || 
          tags.includes(lowerQuery)) {
        results.push({
          element: article,
          title: article.dataset.title,
          description: article.dataset.description,
          tags: article.dataset.tags,
          slug: article.getAttribute('href')?.replace('/posts/', '') || ''
        });
      }
    });
    
    // 更新统计
    searchStats.textContent = `找到 ${results.length} 篇相关文章`;
    
    // 显示结果
    if (results.length > 0) {
      filteredList.innerHTML = results.map(result => `
        <a 
          href="/posts/${result.slug}"
          class="block p-6 bg-white rounded-xl border border-primary-100 hover:border-primary-300 hover:shadow-lg transition-all"
        >
          <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <div class="flex-1">
              <h3 class="text-lg font-semibold text-primary-700 mb-2">${result.title}</h3>
              <p class="text-sm text-primary-400 mb-3 line-clamp-2">${result.description || ''}</p>
              <div class="flex flex-wrap gap-2">
                ${(result.tags || '').split(' ').filter(t => t).map(tag => `
                  <span class="px-2 py-1 bg-primary-50 text-primary-600 text-xs rounded-full">
                    #${tag}
                  </span>
                `).join('')}
              </div>
            </div>
          </div>
        </a>
      `).join('');
      
      defaultResults.classList.add('hidden');
      filteredResults.classList.remove('hidden');
    } else {
      filteredList.innerHTML = `
        <div class="text-center py-12 text-primary-400">
          <svg class="w-16 h-16 mx-auto mb-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <p class="text-lg">没有找到相关文章</p>
          <p class="text-sm">尝试使用不同的关键词</p>
        </div>
      `;
      
      defaultResults.classList.add('hidden');
      filteredResults.classList.remove('hidden');
    }
  }
  
  // 监听搜索输入
  searchInput.addEventListener('input', function(e) {
    performSearch(e.target.value);
  });
  
  // 支持按 Enter 搜索
  searchInput.addEventListener('keypress', function(e) {
    if (e.key === 'Enter') {
      performSearch(e.target.value);
    }
  });
});
</script>
