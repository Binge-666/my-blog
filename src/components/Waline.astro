---
// Waline 评论组件 - 无需登录即可评论
// 需要先部署 Waline 服务端：https://waline.js.org/guide/get-started/

interface Props {
  serverURL: string;
  path?: string;
  dark?: boolean;
}

const {
  serverURL = "https://waline-ra740wo8h-binge-s-projects.vercel.app",
  path = Astro.url.pathname,
  dark = false
} = Astro.props;
---

<div class="waline-comments mt-12 pt-8 border-t border-primary-200">
  <div id="waline-container">
    <link rel="stylesheet" href="/waline.css" />
    <div id="waline" data-server-url={serverURL} data-path={path}></div>
  </div>
</div>

<script type="module">
  import { init } from '/waline.js';

  const walineEl = document.getElementById('waline');
  const serverURL = walineEl.dataset.serverUrl;
  const path = walineEl.dataset.path;

  init({
    el: '#waline',
    serverURL: serverURL,
    path: path,
    dark: document.documentElement.classList.contains('dark'),
    meta: ['nick'],
    requiredMeta: ['nick'],
    login: 'disable',
    locale: {
      placeholder: '欢迎评论，支持 Markdown 语法~',
      nick: '昵称',
      mail: '邮箱（选填）',
      link: '网址（选填）',
      submit: '提交评论',
      comment: '评论',
      reply: '回复',
      cancelReply: '取消回复',
      login: '登录',
      logout: '退出',
      admin: '管理员',
      hot: '最热',
      earlier: '更早',
      later: '最新',
      sofa: '还没有评论，快来抢沙发吧！',
      commentSuccess: '评论成功',
      commentFail: '评论失败，请重试',
      loadComments: '加载评论...',
    }
  });

  const observer = new MutationObserver(() => {
    if (walineEl) {
      walineEl.setAttribute('data-dark', document.documentElement.classList.contains('dark'));
    }
  });
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
</script>

<style>
  .waline-comments {
    max-width: 100%;
  }
  :global(.waline) input[name="mail"],
  :global(.waline) input[name="link"] {
    display: none;
  }
  :global(.waline) .wl-panel {
    border-radius: 12px;
    border: 1px solid var(--color-primary-200);
  }
  :global(.waline) .wl-btn {
    background-color: var(--color-primary-600);
    border-color: var(--color-primary-600);
    border-radius: 8px;
  }
</style>
