---
// src/components/Breadcrumb.astro
// 面包屑导航组件

interface Props {
  items: Array<{
    label: string;
    href?: string;
  }>;
}

const { items } = Astro.props;
---

<nav class="mb-6" aria-label="面包屑导航">
  <ol class="flex items-center text-sm text-primary-400 flex-wrap">
    <li>
      <a href="/" class="hover:text-primary-600 transition-colors flex items-center">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
        首页
      </a>
    </li>
    {items.map((item, index) => (
      <li class="flex items-center">
        <svg class="w-4 h-4 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        {item.href ? (
          <a href={item.href} class="hover:text-primary-600 transition-colors">{item.label}</a>
        ) : (
          <span class="text-primary-600 font-medium">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
